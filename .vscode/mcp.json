{
  "inputs": [
    { "id": "glean_url", "description": "Glean MCP URL (e.g. https://your-org.glean.com/mcp)", "password": false },
    { "id": "glean_token", "description": "Glean API token", "password": true },
    { "id": "confluence_url", "description": "Confluence base URL (e.g. https://your-org.atlassian.net/wiki)", "password": false },
    { "id": "confluence_token", "description": "Confluence API token", "password": true },
    { "id": "miro_token", "description": "Miro API token", "password": true },
    { "id": "github_token", "description": "GitHub Personal Access Token", "password": true }
  ],
  "servers": {
    "glean": {
      "type": "http",
      "url": "${input:glean_url}",
      "headers": {
        "Authorization": "Bearer ${input:glean_token}"
      }
    },
    "confluence": {
      "command": "npx",
      "args": ["-y", "@confluence/mcp-server"],
      "env": {
        "CONFLUENCE_URL": "${input:confluence_url}",
        "CONFLUENCE_TOKEN": "${input:confluence_token}"
      }
    },
    "miro": {
      "command": "npx",
      "args": ["-y", "@mirohq/mcp-server"],
      "env": {
        "MIRO_ACCESS_TOKEN": "${input:miro_token}"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_token}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
    }
  }
}
